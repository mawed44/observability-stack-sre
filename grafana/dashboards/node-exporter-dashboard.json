{
  "title": "Observabilité moderne – Node Exporter",
  "uid": "node-exporter-modern",
  "description": "Métriques essentielles de l’environnement Linux Docker/WSL2.",
  "tags": ["observabilité", "prometheus", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU utilisé",
      "description": "Utilisation moyenne de tous les cœurs sur cinq minutes.",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
          "legendFormat": "CPU",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 70},
              {"color": "red", "value": 80}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Mémoire utilisée",
      "description": "Part de la mémoire qui n’est plus disponible.",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Mémoire",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Disque le plus utilisé",
      "description": "Taux d’occupation maximal parmi les disques persistants.",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max(100 * (1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|rootfs|fuse.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|rootfs|fuse.*\"})))",
          "legendFormat": "Disque",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Durée de fonctionnement",
      "description": "Temps écoulé depuis le démarrage de Linux/WSL2.",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "Durée",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Évolution du CPU et de la mémoire",
      "description": "Historique des deux principales ressources en pourcentage.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
          "legendFormat": "CPU"
        },
        {
          "refId": "B",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Mémoire"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 80}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Trafic réseau",
      "description": "Débit moyen reçu et envoyé sur cinq minutes.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "Reçu – {{device}}"
        },
        {
          "refId": "B",
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "Envoyé – {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Charge système",
      "description": "Charge moyenne sur 1, 5 et 15 minutes, rapportée au nombre de cœurs.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * node_load1 / scalar(count(count(node_cpu_seconds_total{mode=\"idle\"}) by (cpu)))",
          "legendFormat": "1 minute",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "100 * node_load5 / scalar(count(count(node_cpu_seconds_total{mode=\"idle\"}) by (cpu)))",
          "legendFormat": "5 minutes",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "100 * node_load15 / scalar(count(count(node_cpu_seconds_total{mode=\"idle\"}) by (cpu)))",
          "legendFormat": "15 minutes",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 70},
              {"color": "red", "value": 100}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Répartition de la mémoire",
      "description": "Comparaison entre la mémoire utilisée et la mémoire disponible.",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Utilisée",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Disponible",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "percent"],
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"]},
        "tooltip": {"mode": "single", "sort": "none"},
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Occupation des disques",
      "description": "Pourcentage utilisé pour chaque périphérique persistant.",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (device) (100 * (1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|rootfs|fuse.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|rootfs|fuse.*\"})))",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [{"displayName": "Value", "desc": true}]
      }
    },
    {
      "id": 10,
      "type": "state-timeline",
      "title": "Disponibilité de Node Exporter",
      "description": "Historique de l’état de la cible surveillée par Prometheus.",
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"node-exporter\"}",
          "legendFormat": "Node Exporter"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "Indisponible", "color": "red"},
                "1": {"text": "Disponible", "color": "green"}
              }
            }
          ],
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        },
        "overrides": []
      },
      "options": {
        "alignValue": "left",
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": false},
        "mergeValues": true,
        "rowHeight": 0.8,
        "showValue": "always",
        "tooltip": {"mode": "single", "sort": "none"}
      }
    }
  ]
}
